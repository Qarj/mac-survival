{
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "[python]": {
        "editor.defaultFormatter": null
    },
    "python.formatting.provider": "black",
    "python.formatting.blackArgs": ["--line-length", "120"],
    "python.formatting.autopep8Args": ["--max-line-length=120"],
    "editor.formatOnSave": true,
    "editor.formatOnPaste": false,
    "search.exclude": {
        "**/downloads": true,
        "**/.git": true,
        "**/node_modules": true,
        "**/screenshots": true,
        "**/test-reports*": true
    },
    "cSpell.words": [
        "chsh",
        "DHAVE",
        "DLOCALEDIR",
        "DNDEBUG",
        "DSYSTEM",
        "freerdp",
        "gpgme",
        "Hrvoje",
        "iterm",
        "keyboardtype",
        "koekeishiya",
        "lcrypto",
        "libgnu",
        "libidn",
        "liconv",
        "lidn",
        "lintl",
        "lssl",
        "lunistring",
        "metalink",
        "neofetch",
        "Niksic",
        "opie",
        "rasa",
        "Rasa",
        "setuptools",
        "spctl",
        "wgetrc",
        "Wgetrc",
        "WGETRC",
        "xfreerdp",
        "xquartz",
        "yabai"
    ]
}
